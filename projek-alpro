  window.setRandomBinary = () => {
    let arr = Array.from({length:100}, () => Math.floor(Math.random()*10000));
    document.getElementById('binaryDataRaw').value = arr.join(', ');
    document.getElementById('binaryTarget').value = arr[Math.floor(Math.random()*100)];
  };

  document.getElementById('btnLinearCari').addEventListener('click', () => {
    const raw = document.getElementById('linearData').value;
    const target = Number(document.getElementById('linearTarget').value);
    if (isNaN(target)) { document.getElementById('linearResult').innerHTML = '❌ Target harus angka'; return; }
    const arr = parseArrayFromInput(raw);
    if (!arr.length) { document.getElementById('linearResult').innerHTML = '❌ Data kosong'; return; }
    const res = linearSearch(arr, target);
    if (res.found) {
      document.getElementById('linearResult').innerHTML = `✅ DITEMUKAN!<br>Indeks: ${res.index}<br>Perbandingan: ${res.comparisons} elemen`;
    } else {
      document.getElementById('linearResult').innerHTML = `❌ TIDAK DITEMUKAN<br>Memeriksa ${res.comparisons} elemen`;
    }
  });

  document.getElementById('btnBinaryCari').addEventListener('click', () => {
    const raw = document.getElementById('binaryDataRaw').value;
    const target = Number(document.getElementById('binaryTarget').value);
    if (isNaN(target)) { document.getElementById('binaryResult').innerHTML = '❌ Target harus angka'; return; }
    let original = parseArrayFromInput(raw);
    if (!original.length) { document.getElementById('binaryResult').innerHTML = '❌ Data kosong'; return; }
    const sorted = [...original].sort((a,b)=>a-b);
    const res = binarySearchOnSorted(sorted, target);
    if (res.found) {
      document.getElementById('binaryResult').innerHTML = `✅ DITEMUKAN!<br>Indeks (setelah urut): ${res.index}<br>Langkah: ${res.steps}`;
    } else {
      document.getElementById('binaryResult').innerHTML = `❌ TIDAK DITEMUKAN<br>Langkah pencarian: ${res.steps}`;
    }
  });

  // Jalankan pengecekan session saat halaman dimuat
  checkExistingSession();
</script>
