  });

  // ======================= FUNGSI ALGORITMA PENCARIAN =======================
  function parseArrayFromInput(str) {
    let cleaned = str.replace(/\n/g, ',').replace(/\t/g, ',').replace(/\s+/g, ',');
    let parts = cleaned.split(',');
    let arr = [];
    for (let part of parts) {
      let trimmed = part.trim();
      if (trimmed !== "") {
        let num = Number(trimmed);
        if (!isNaN(num)) arr.push(num);
      }
    }
    return arr;
  }

  function linearSearch(arr, target) {
    for (let i = 0; i < arr.length; i++) {
      if (arr[i] === target) return { found: true, index: i, comparisons: i + 1 };
    }
    return { found: false, comparisons: arr.length };
  }

  function binarySearchOnSorted(sortedArr, target) {
    let left = 0, right = sortedArr.length - 1, steps = 0;
    while (left <= right) {
      steps++;
      const mid = Math.floor((left + right) / 2);
      if (sortedArr[mid] === target) return { found: true, index: mid, steps };
      if (sortedArr[mid] < target) left = mid + 1;
      else right = mid - 1;
    }
    return { found: false, steps };
  }

