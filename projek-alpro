    <!-- Panel algoritma -->
    <div class="algo-panel">
      <!-- LINEAR SEARCH PANEL -->
      <div class="panel-card">
        <div class="card-header linear-header">
          <h2><span>🔍</span> Linear Search <span class="complexity-tag">O(n)</span></h2>
          <p style="font-size:0.75rem; margin-top:6px;">Pencarian berurutan · Data TIDAK perlu terurut · Tanpa batas data</p>
        </div>
        <div class="card-body">
          <div class="input-group">
            <label>📊 Data Array (pisahkan dengan koma, spasi, atau enter) — <span class="warning-badge">bisa ribuan data</span></label>
