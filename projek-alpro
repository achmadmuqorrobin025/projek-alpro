  function findUserByInput(input) {
    input = input.trim().toLowerCase();
    if (/^\d+$/.test(input) && DATA_MAHASISWA[input]) return DATA_MAHASISWA[input];
    for (let nim in DATA_MAHASISWA) {
      if (DATA_MAHASISWA[nim].email && DATA_MAHASISWA[nim].email.toLowerCase() === input) return DATA_MAHASISWA[nim];
    }
    return null;
  }

  // ======================= SESSION MANAGEMENT (BERDASARKAN WAKTU REAL DEVICE) =======================
  let currentUser = null;
  let sessionCheckInterval = null;
  const SESSION_DURATION_HOURS = 1; // 1 jam

  function saveLoginTime() {
    localStorage.setItem('loginTime', Date.now().toString());
    localStorage.setItem('sessionActive', 'true');
  }

  function getLoginTime() {
    const loginTimeStr = localStorage.getItem('loginTime');
    if (!loginTimeStr) return null;
    return parseInt(loginTimeStr);
  }

  function isSessionExpired() {
    const loginTime = getLoginTime();
    if (!loginTime) return true;
    const now = Date.now();
    const diffMs = now - loginTime;
    const diffHours = diffMs / (1000 * 60 * 60);
    return diffHours >= SESSION_DURATION_HOURS;
  }

  function autoLogoutByTime() {
    if (!currentUser && mainApp.style.display !== 'block') return;
    
    // Hapus session storage
    localStorage.removeItem('loginTime');
    localStorage.removeItem('sessionActive');
    localStorage.removeItem('currentUserData');
    
    if (sessionCheckInterval) {
      clearInterval(sessionCheckInterval);
      sessionCheckInterval = null;
    }
    
    currentUser = null;
    mainApp.style.display = 'none';
    loginPage.style.display = 'block';
    loginUsername.value = '';
    loginPassword.value = '';
    
    // Tampilkan pesan session berakhir
    const errorDiv = document.getElementById('loginErrorMsg');
    if (errorDiv) {
      errorDiv.style.display = 'block';
      errorDiv.innerHTML = '⏰ Sesi Anda telah berakhir (1 jam). Silakan login kembali.';
      setTimeout(() => {
        errorDiv.style.display = 'none';
      }, 5000);
    }
  }

  function startSessionChecker() {
    if (sessionCheckInterval) clearInterval(sessionCheckInterval);
    sessionCheckInterval = setInterval(() => {
      if (currentUser && isSessionExpired()) {
        autoLogoutByTime();
      }
    }, 10000); // Cek setiap 10 detik
  }

  function stopSessionChecker() {
    if (sessionCheckInterval) {
      clearInterval(sessionCheckInterval);
      sessionCheckInterval = null;
    }
  }

  // Cek session saat halaman dimuat (refresh/tutup browser)
  function checkExistingSession() {
    const savedUserStr = localStorage.getItem('currentUserData');
    const loginTime = getLoginTime();
    
    if (savedUserStr && loginTime && !isSessionExpired()) {
      // Session masih valid
      const user = JSON.parse(savedUserStr);
      currentUser = user;
      loginPage.style.display = 'none';
      mainApp.style.display = 'block';
      document.getElementById('userFullName').textContent = user.nama;
      document.getElementById('userNim').textContent = `NIM: ${user.nim}`;
      startSessionChecker();
    } else if (savedUserStr && loginTime && isSessionExpired()) {
      // Session expired
      localStorage.removeItem('loginTime');
      localStorage.removeItem('sessionActive');
      localStorage.removeItem('currentUserData');
      loginPage.style.display = 'flex';
      mainApp.style.display = 'none';
    } else {
      loginPage.style.display = 'flex';
      mainApp.style.display = 'none';
    }
  }

  // ======================= LOGIN & LOGOUT =======================
  const loginPageDiv = document.getElementById('loginPage');
  const mainAppDiv = document.getElementById('mainApp');
  const loginBtnElem = document.getElementById('btnLoginSubmit');
  const loginUsernameElem = document.getElementById('loginUsername');
  const loginPasswordElem = document.getElementById('loginPassword');
  const loginErrorMsgElem = document.getElementById('loginErrorMsg');
  const logoutBtnElem = document.getElementById('logoutBtn');

  function attemptLogin() {
    const input = loginUsernameElem.value.trim();
    const password = loginPasswordElem.value.trim();
    const user = findUserByInput(input);
    
    if (user && password === "alpro2026") {
      currentUser = user;
      
      // Simpan session ke localStorage
      saveLoginTime();
      localStorage.setItem('currentUserData', JSON.stringify({ 
        nama: user.nama, 
        nim: user.nim,
        email: user.email 
      }));
      
      loginPageDiv.style.display = 'none';
      mainAppDiv.style.display = 'block';
      document.getElementById('userFullName').textContent = user.nama;
      document.getElementById('userNim').textContent = `NIM: ${user.nim}`;
      loginErrorMsgElem.style.display = 'none';
      
      // Mulai pengecekan session
      startSessionChecker();
    } else {
      loginErrorMsgElem.style.display = 'block';
      loginErrorMsgElem.innerHTML = '❌ NIM atau password salah! Gunakan password: <strong>alpro2026</strong>';
    }
  }

  function logout() {
    // Hapus semua data session
    localStorage.removeItem('loginTime');
    localStorage.removeItem('sessionActive');
    localStorage.removeItem('currentUserData');
    
    stopSessionChecker();
    
    currentUser = null;
    mainAppDiv.style.display = 'none';
    loginPageDiv.style.display = 'block';
    loginUsernameElem.value = '';
    loginPasswordElem.value = '';
    loginErrorMsgElem.style.display = 'none';
  }

  loginBtnElem.addEventListener('click', attemptLogin);
  if (logoutBtnElem) logoutBtnElem.addEventListener('click', logout);
  
  loginUsernameElem.addEventListener('keypress', (e) => { if (e.key === 'Enter') attemptLogin(); });
  loginPasswordElem.addEventListener('keypress', (e) => { if (e.key === 'Enter') attemptLogin(); });
  
